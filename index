  { id:28, code:"FLOD28", topic:"Genel", title:"Kapsam dışı durumlar", puan:0, criteria:[ {text:"Genel standart dışı tespit var mı?", puan:0} ], standards:`• Liste dışı tüm uygunsuzluklar buraya not edilmelidir.` }
];

const state_obj = {};
AUDIT_DATA.forEach(d => { state_obj[d.id] = { note:'', images:[], criteriaStatus: new Array(d.criteria.length).fill(null) }; });

const SECTION_GROUPS = { "Operasyonel Süreçler": { icon:"⚙️", color:"var(--amber)" }, "Mali Süreçler": { icon:"💰", color:"var(--green)" }, "İnsan Kaynakları Süreçleri": { icon:"👥", color:"#BF5AF2" }, "İş Sağlığı ve Güvenliği Süreçleri": { icon:"🛡️", color:"var(--blue)" }, "Genel": { icon:"📋", color:"var(--muted)" } };

// ==================== ACTIONS ====================
function startAudit() {
  const c = document.getElementById('inpStoreCode').value.trim(), n = document.getElementById('inpStoreName').value.trim(), a = document.getElementById('inpAuditor').value.trim();
  if(!c || !n || !a) return alert("Lütfen tüm alanları doldurun.");
  currentStoreCode = c; currentStoreName = n; currentAuditor = a;
  document.getElementById('auditCodeBadge').innerText = `${currentStoreName} Dijital Denetim`;
  document.getElementById('startupModal').classList.remove('open');
  render(); updateScores();
}

function checkAdminAuth() {
  const user = document.getElementById('inpAdminUser').value.trim();
  const pass = document.getElementById('inpAdminPass').value;
  if(user === "admin" && pass === "ArdaFlo2026!") { document.getElementById('adminAuthModal').classList.remove('open'); openAdminPanel(); }
  else alert("Hatalı kullanıcı adı veya şifre!");
}

function render() {
  const container = document.getElementById('mainContainer'), item = AUDIT_DATA[currentQuestionIndex], g = SECTION_GROUPS[item.topic] || {icon:'📌',color:'var(--muted)'};
  const isLast = currentQuestionIndex === AUDIT_DATA.length - 1;
  const nextBtn = isLast ? `<button onclick="finishAudit()" class="btn-nav btn-finish">Denetimi Bitir ✓</button>` : `<button onclick="nextQ()" class="btn-nav">Sonraki Madde →</button>`;
  container.innerHTML = `<div class="section-group"><div class="section-group-title"><span class="section-icon">${g.icon}</span><span style="color:${g.color}">${item.topic}</span></div>${renderCard(item)}</div><div class="pagination-controls print-hide"><button onclick="prevQ()" class="btn-nav" ${currentQuestionIndex === 0 ? 'disabled' : ''}>← Geri</button><div class="page-indicator">Madde ${currentQuestionIndex + 1} / ${AUDIT_DATA.length}</div>${nextBtn}</div>`;
}

function prevQ() { if(currentQuestionIndex > 0) { currentQuestionIndex--; render(); window.scrollTo(0,0); } }
function nextQ() { if(currentQuestionIndex < AUDIT_DATA.length - 1) { currentQuestionIndex++; render(); window.scrollTo(0,0); } }

function renderCard(item) {
  const s = state_obj[item.id];
  let criteriaHtml = '', showExtras = false;
  item.criteria.forEach((c, idx) => {
    const st = s.criteriaStatus[idx];
    if (st === 'tespit' || st === 'yok') showExtras = true;
    criteriaHtml += `<div class="criterion-row ${st==='na'?'na-active':''}"><div class="criterion-text-box"><div class="criterion-text">${c.text}</div><div class="criterion-pts">${c.puan} Puan</div></div><div class="card-actions" style="margin-top:10px;"><button class="btn-action btn-tespit ${st==='tespit'?'active':''}" onclick="setCriterionStatus(${item.id},${idx},'tespit')">⚠ Tespit Var</button><button class="btn-action btn-yok ${st==='yok'?'active':''}" onclick="setCriterionStatus(${item.id},${idx},'yok')">✓ Tespit Yok</button><button class="btn-action btn-na ${st==='na'?'active':''}" onclick="setCriterionStatus(${item.id},${idx},'na')">— N/A</button></div></div>`;
  });
  return `<div class="audit-card"><div class="card-header"><div class="card-num">${String(item.id).padStart(2,'0')}</div><div class="card-meta"><div class="card-code">${item.code}</div><div class="card-title">${item.title}</div></div><button class="info-btn" onclick="showDetail(${item.id})">ℹ</button></div><div class="criteria-list">${criteriaHtml}</div><div class="extras-area"><div class="image-upload-area ${s.criteriaStatus.includes('tespit')?'visible':''}"><label class="upload-label">📸 Fotoğraf Ekle<input type="file" accept="image/*" multiple onchange="addImages(${item.id},this)"></label><div class="uploaded-images">${s.images.map((src,i)=>`<img class="uploaded-img-thumb" src="${src}" onclick="removeImage(${item.id},${i})">`).join('')}</div></div><textarea class="note-input ${showExtras?'visible':''}" placeholder="Denetim notu yazın..." onchange="state_obj[${item.id}].note=this.value">${s.note}</textarea></div></div>`;
}

function setCriterionStatus(id, idx, st) { state_obj[id].criteriaStatus[idx] = (state_obj[id].criteriaStatus[idx] === st ? null : st); render(); updateScores(); }
function addImages(id, inp) { Array.from(inp.files).forEach(f => { const r = new FileReader(); r.onload = e => { state_obj[id].images.push(e.target.result); render(); }; r.readAsDataURL(f); }); }
function removeImage(id, idx) { state_obj[id].images.splice(idx,1); render(); }

function updateScores() {
  let earned = 0, answered = 0, cT=0, cY=0, cN=0;
  AUDIT_DATA.forEach(d => {
    state_obj[d.id].criteriaStatus.forEach((st, i) => { if(st) answered++; if(st==='yok'||st==='na') earned+=d.criteria[i].puan; if(st==='tespit') cT++; else if(st==='yok') cY++; else if(st==='na') cN++; });
  });
  document.getElementById('totalScore').innerHTML = `${earned} <span style="font-size:14px;color:var(--muted)">/ 100</span>`;
  document.getElementById('progressFill').style.width = (answered / 33 * 100) + '%';
  document.getElementById('cntTespit').innerText = cT; document.getElementById('cntYok').innerText = cY; document.getElementById('cntNA').innerText = cN; document.getElementById('cntPending').innerText = 33-answered;
}

function finishAudit() {
  let missing = 0; AUDIT_DATA.forEach(d => d.criteria.forEach((c,i) => { if(!state_obj[d.id].criteriaStatus[i]) missing++; }));
  if(missing > 0) return alert(`Lütfen ${missing} adet boş kriteri doldurun.`);
  const btn = document.querySelector('.btn-finish'); btn.innerHTML = "Rapor Oluşturuluyor...";
  const payload = { storeCode: currentStoreCode, storeName: currentStoreName, auditor: currentAuditor, date: new Date().toISOString(), score: document.getElementById('totalScore').innerText.split('/')[0].trim(), details: AUDIT_DATA.map(d => ({ code:d.code, topic:d.topic, title:d.title, note:state_obj[d.id].note, images:state_obj[d.id].images, results:d.criteria.map((c,i)=>({text:c.text, status:state_obj[d.id].criteriaStatus[i], puan:c.puan})) })) };
  db.collection("denetimler").add(payload).then(() => { generateReportHTML(payload); btn.innerHTML = "Tamamlandı ✓"; });
}

async function openAdminPanel() {
  const area = document.getElementById('adminDataArea'); area.innerHTML = "Yükleniyor...";
  document.getElementById('adminDataModal').classList.add('open');
  const snap = await db.collection("denetimler").orderBy("date","desc").get();
  if(snap.empty) { area.innerHTML = "Kayıt yok."; return; }
  let html = `<table class="report-table"><thead><tr><th>Tarih</th><th>Mağaza</th><th>Denetmen</th><th>Puan</th><th>İşlem</th></tr></thead><tbody>`;
  snap.forEach(doc => { const d = doc.data(); adminDataCache[doc.id] = d; html += `<tr><td>${new Date(d.date).toLocaleDateString()}</td><td>${d.storeCode} - ${d.storeName}</td><td>${d.auditor}</td><td>${d.score}</td><td><button class="admin-btn" onclick="generateReportHTML(adminDataCache['${doc.id}'])">Görüntüle</button></td></tr>`; });
  area.innerHTML = html + `</tbody></table>`;
}

function showDetail(id) {
  const item = AUDIT_DATA.find(d=>d.id===id);
  const list = item.standards.split('\n').filter(l=>l.trim()).map(l => `<li><span class="blue-arrow">→</span><span>${l.replace(/^•\s*/,'')}</span></li>`).join('');
  document.getElementById('detailModalBody').innerHTML = `<div style="color:var(--primary);font-size:12px;font-weight:700;margin-bottom:8px;">${item.code}</div><h2 style="text-align:left;font-size:18px;">${item.title}</h2><ul class="standards-list" style="margin-top:20px;">${list}</ul>`;
  document.getElementById('detailModal').classList.add('open');
}

function generateReportHTML(d) {
  const groups = {}; let cT=0, cY=0, cN=0;
  d.details.forEach(det => { if(!groups[det.topic]) groups[det.topic] = []; groups[det.topic].push(det); det.results.forEach(r => { if(r.status==='na') cN++; else if(r.status==='yok') cY++; else cT++; }); });
  let chapters = '';
  for(const [topic, items] of Object.entries(groups)) {
    let rows = '';
    items.forEach(it => {
      it.results.forEach((r, idx) => {
        const b = r.status==='tespit'?'t':(r.status==='yok'?'y':'n'), txt = r.status==='na'?'N/A':(r.status==='yok'?'Tespit Yok':'Tespit Var');
        let extra = (idx === it.results.length - 1) ? (it.note?`<div style="font-size:11px;color:#666;margin-top:5px;">Not: ${it.note}</div>`:'') + (it.images?.length?`<div class="report-img-wrapper">${it.images.map(img=>`<img src="${img}" class="report-img">`).join('')}</div>`:'') : '';
        rows += `<tr style="${r.status==='na'?'opacity:0.6':''}">` + (idx===0?`<td rowspan="${it.results.length}" style="font-weight:700;color:red;width:10%">${it.code}</td>`:'') + `<td>${r.text}${extra}</td><td><span class="badge-s ${b}">${txt}</span></td><td style="text-align:center;font-weight:700;">${(r.status==='tespit'?0:r.puan)}</td></tr>`;
      });
    });
    chapters += `<div class="print-chapter-title">${topic}</div><table class="report-table"><thead><tr><th>Kod</th><th>Kriter</th><th>Sonuç</th><th>Puan</th></tr></thead><tbody>${rows}</tbody></table>`;
  }
  document.getElementById('reportModalBody').innerHTML = `<div style="text-align:center;margin-bottom:30px;border-bottom:1px solid #eee;padding-bottom:20px;"><h2 style="font-size:24px;color:#000;">Denetim Sonuç Raporu</h2><p style="color:#666;margin-top:10px;">Mağaza: <b>${d.storeCode} - ${d.storeName}</b> &bull; Denetmen: <b>${d.auditor}</b> &bull; Tarih: ${new Date(d.date).toLocaleDateString()}</p><button class="print-btn-large print-hide" onclick="window.print()">🖨 Raporu PDF / Yazdır</button></div><div style="display:flex;gap:10px;margin-bottom:20px;"><div class="modal-score-box"><div class="v">${d.score} / 100</div><div class="l">Mevcut Puan</div></div><div class="modal-score-box"><div class="v" style="color:red">${cT}</div><div class="l">Tespit</div></div><div class="modal-score-box"><div class="v" style="color:green">${cY}</div><div class="l">Tespit Yok</div></div><div class="modal-score-box"><div class="v">${cN}</div><div class="l">N/A</div></div></div>${chapters}`;
  document.getElementById('reportModal').classList.add('open');
}

function closeModal(id) { document.getElementById(id).classList.remove('open'); }
</script>
